{
  "name": "@zterm/android",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper ../node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null; command -v portless >/dev/null 2>&1 || (echo '\\nportless is required but not installed. Run: npm i -g portless\\n' && exit 1)",
    "dev": "portless android.zterm vite",
    "build": "node ./scripts/bump-build-version.mjs && tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "serve:server": "chmod +x node_modules/node-pty/prebuilds/darwin-*/spawn-helper ../node_modules/node-pty/prebuilds/darwin-*/spawn-helper 2>/dev/null; tsx src/server/server.ts",
    "daemon": "bash ./scripts/zterm-daemon.sh",
    "daemon:start": "./scripts/start-tmux-daemon.sh",
    "daemon:status": "./scripts/status-tmux-daemon.sh",
    "daemon:stop": "./scripts/stop-tmux-daemon.sh",
    "daemon:mirror:lab": "tsx scripts/daemon-mirror-lab.ts",
    "daemon:mirror:lab:current": "bash ./scripts/run-daemon-mirror-lab.sh",
    "daemon:mirror:replay": "tsx scripts/client-mirror-replay.ts",
    "daemon:mirror:close-loop": "tsx scripts/daemon-mirror-close-loop.ts",
    "daemon:runtime:analyze": "tsx scripts/analyze-runtime-debug.ts",
    "daemon:install-global": "bash ./scripts/install-global-daemon-cli.sh",
    "daemon:install-service": "bash ./scripts/zterm-daemon.sh install-service",
    "daemon:service-status": "bash ./scripts/zterm-daemon.sh service-status",
    "sync:android": "npx cap sync android",
    "run:android": "npx cap run android",
    "build:android": "./scripts/build-android-debug.sh",
    "prepare:update-bundle": "node ./scripts/prepare-update-bundle.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.0.0",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@jsonstudio/wtermmod-core": "^0.1.9",
    "@jsonstudio/wtermmod-dom": "^0.1.9",
    "@jsonstudio/wtermmod-react": "^0.1.9",
    "@zterm/shared": "workspace:*",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0",
    "ws": "^8.18.0"
  },
  "packageManager": "pnpm@9.15.9"
}
