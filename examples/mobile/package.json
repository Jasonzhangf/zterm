{
  "name": "@wterm/mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:runtime": "node --import tsx ./scripts/prepare-runtime.ts",
    "postinstall": "node --import tsx ./scripts/prepare-runtime.ts",
    "predev": "node --import tsx ./scripts/prepare-runtime.ts && command -v portless >/dev/null 2>&1 || (echo '\\nportless is required but not installed. Run: npm i -g portless\\n' && exit 1)",
    "dev": "portless mobile.wterm vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "serve:server": "node --import tsx ./scripts/prepare-runtime.ts && tsx src/server/server.ts",
    "daemon": "bash ./scripts/wterm-mobile-daemon.sh",
    "daemon:start": "./scripts/start-tmux-daemon.sh",
    "daemon:status": "./scripts/status-tmux-daemon.sh",
    "daemon:stop": "./scripts/stop-tmux-daemon.sh",
    "daemon:install-global": "bash ./scripts/install-global-daemon-cli.sh",
    "daemon:install-service": "bash ./scripts/wterm-mobile-daemon.sh install-service",
    "daemon:service-status": "bash ./scripts/wterm-mobile-daemon.sh service-status",
    "sync:android": "npx cap sync android",
    "run:android": "npx cap run android",
    "build:android": "./scripts/build-android-debug.sh"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.0.0",
    "@capacitor/keyboard": "^6.0.4",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@wterm/core": "workspace:*",
    "@wterm/dom": "workspace:*",
    "@wterm/react": "workspace:*",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0",
    "ws": "^8.18.0"
  },
  "packageManager": "pnpm@9.15.9"
}
